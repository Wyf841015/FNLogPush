#!/bin/bash

set -u

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"

_app_install_root() {
    local src="${BASH_SOURCE[0]:-$0}"
    cd -P "$(dirname "${src}")/.." && pwd
}

resolve_app_code_dir() {
    local root cmd_dir trim_dest d
    root="$(_app_install_root)"
    cmd_dir="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    trim_dest="${TRIM_APPDEST:-}"

    for d in \
        "${cmd_dir}/logmonitor" \
        "${root}/app/server" \
        "${root}/target" \
        "${root}/target/logmonitor"
    do
        if [ -f "${d}/requirements.txt" ] && [ -f "${d}/src/main.py" ]; then
            printf "%s" "${d}"
            return 0
        fi
    done

    if [ -n "${trim_dest}" ]; then
        for d in \
            "${trim_dest}/target" \
            "${trim_dest}/target/logmonitor" \
            "${trim_dest}/app/server"
        do
            if [ -f "${d}/requirements.txt" ] && [ -f "${d}/src/main.py" ]; then
                printf "%s" "${d}"
                return 0
            fi
        done
    fi
    return 1
}

build_cmd() {
    local app_code_dir app_main py pypath
    app_code_dir="$(resolve_app_code_dir)" || return 1
    app_main="${app_code_dir}/src/main.py"

    if [ -x "${TRIM_PKGVAR}/venv/bin/python" ] && [ ! -f "${TRIM_PKGVAR}/.use_python_target" ]; then
        py="${TRIM_PKGVAR}/venv/bin/python"
        pypath="${app_code_dir}"
    elif [ -f "${TRIM_PKGVAR}/.use_python_target" ] && [ -d "${TRIM_PKGVAR}/python_modules" ]; then
        py="python3"
        pypath="${app_code_dir}:${TRIM_PKGVAR}/python_modules"
    else
        return 1
    fi

    local ui_port="${TRIM_SERVICE_PORT:-19800}"
    printf '%s' "export APP_HOME=\"${TRIM_PKGVAR}\"; export PYTHONUNBUFFERED=1; export UI_PORT=\"${ui_port}\"; export PYTHONPATH=\"${pypath}\"; cd \"${TRIM_PKGVAR}\"; \"${py}\" -u \"${app_main}\""
}

fail_user_visible() {
    local msg="$1"
    if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
        printf "%s\n" "${msg}" > "${TRIM_TEMP_LOGFILE}"
    fi
    exit 1
}

log_msg() {
    mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting process ..."
    local cmd_line
    if ! cmd_line="$(build_cmd)"; then
        fail_user_visible "启动失败：未找到应用代码或未安装依赖（无 venv 且无 python_modules）。应用根: $(_app_install_root)。请重新安装应用。"
    fi
    bash -c "${cmd_line}" >> ${LOG_FILE} 2>&1 &
    printf "%s" "$!" > ${PID_FILE}
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file 1"
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
        else
            log_msg "process killed... "
        fi
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi    
    fi

    return 1
}

case $1 in
start)
    start_process
    exit $?
    ;;
stop)
    stop_process
    exit $?
    ;;
status)
    if status; then 
        exit 0
    else 
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
