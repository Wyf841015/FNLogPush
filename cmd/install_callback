#!/bin/bash

### This script is called after the user installs the application.

set -euo pipefail

fail_user_visible() {
    local msg="$1"
    if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
        printf "%s\n" "${msg}" > "${TRIM_TEMP_LOGFILE}"
    fi
    exit 1
}

if ! command -v python3 >/dev/null 2>&1; then
    fail_user_visible "安装失败：未找到 python3。请在 fnOS 上安装/启用 Python 3.9+ 运行时后重试。"
fi

PYVER="$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' || true)"
if [ -z "${PYVER}" ]; then
    fail_user_visible "安装失败：无法获取 Python 版本。"
fi

REQ_PY_OK="$(python3 -c 'import sys; print(int(sys.version_info >= (3,9)))' || true)"
if [ "${REQ_PY_OK}" != "1" ]; then
    fail_user_visible "安装失败：需要 Python >= 3.9，当前为 ${PYVER}。"
fi

_app_install_root() {
    local src="${BASH_SOURCE[0]:-$0}"
    cd -P "$(dirname "${src}")/.." && pwd
}

resolve_app_code_dir() {
    local root cmd_dir trim_dest d
    root="$(_app_install_root)"
    cmd_dir="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    trim_dest="${TRIM_APPDEST:-}"

    for d in \
        "${cmd_dir}/logmonitor" \
        "${root}/app/server" \
        "${root}/target" \
        "${root}/target/logmonitor"
    do
        if [ -f "${d}/requirements.txt" ] && [ -f "${d}/src/main.py" ]; then
            printf "%s" "${d}"
            return 0
        fi
    done

    if [ -n "${trim_dest}" ]; then
        for d in \
            "${trim_dest}/target" \
            "${trim_dest}/target/logmonitor" \
            "${trim_dest}/app/server"
        do
            if [ -f "${d}/requirements.txt" ] && [ -f "${d}/src/main.py" ]; then
                printf "%s" "${d}"
                return 0
            fi
        done
    fi
    return 1
}

if ! APP_CODE_DIR="$(resolve_app_code_dir)"; then
    fail_user_visible "安装失败：未找到应用代码目录。需要 cmd/logmonitor/requirements.txt 与 cmd/logmonitor/src/main.py"
fi

REQ_FILE="${APP_CODE_DIR}/requirements.txt"
DEFAULT_CONFIG_FILE="${APP_CODE_DIR}/config/config.json"

if [ ! -f "${REQ_FILE}" ]; then
    fail_user_visible "安装失败：未找到依赖文件 requirements.txt（${REQ_FILE}）。"
fi

mkdir -p "${TRIM_PKGVAR}" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/logs"

if ! touch "${TRIM_PKGVAR}/.test_write" 2>/dev/null; then
    fail_user_visible "安装失败：无法在数据目录写入（${TRIM_PKGVAR}）。"
fi
rm -f "${TRIM_PKGVAR}/.test_write"

if [ ! -f "${TRIM_PKGVAR}/config/config.json" ]; then
    if [ -f "${DEFAULT_CONFIG_FILE}" ]; then
        cp -f "${DEFAULT_CONFIG_FILE}" "${TRIM_PKGVAR}/config/config.json"
    fi
fi

# 生成并保存加密密钥（如果不存在）
if [ ! -f "${TRIM_PKGVAR}/config/.encrypt_key" ]; then
    ENCRYPT_KEY="$(python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())' 2>/dev/null || echo "")"
    if [ -n "${ENCRYPT_KEY}" ]; then
        echo "${ENCRYPT_KEY}" > "${TRIM_PKGVAR}/config/.encrypt_key"
        chmod 600 "${TRIM_PKGVAR}/config/.encrypt_key" 2>/dev/null || true
    fi
fi

# 处理 events.json 配置（如果不存在则复制）
DEFAULT_EVENTS_FILE="${APP_CODE_DIR}/config/events.json"
if [ ! -f "${TRIM_PKGVAR}/config/events.json" ]; then
    if [ -f "${DEFAULT_EVENTS_FILE}" ]; then
        cp -f "${DEFAULT_EVENTS_FILE}" "${TRIM_PKGVAR}/config/events.json"
    fi
fi

_append_venv_log() {
    local f="$1"
    if [ -n "${TRIM_TEMP_LOGFILE:-}" ] && [ -f "${f}" ]; then
        {
            printf "\n--- venv 命令输出（节选）---\n"
            head -80 "${f}"
        } >> "${TRIM_TEMP_LOGFILE}"
    fi
    rm -f "${f}"
}

_try_create_venv() {
    local err
    err="$(mktemp)"
    rm -rf "${VENV_DIR}" 2>/dev/null || true
    if python3 -m venv --copies "${VENV_DIR}" 2>"${err}"; then
        rm -f "${err}"
        return 0
    fi
    rm -rf "${VENV_DIR}" 2>/dev/null || true
    if python3 -m venv "${VENV_DIR}" 2>"${err}"; then
        rm -f "${err}"
        return 0
    fi
    _append_venv_log "${err}"
    return 1
}

_install_with_venv() {
    rm -f "${TRIM_PKGVAR}/.use_python_target" 2>/dev/null || true
    if ! _try_create_venv; then
        return 1
    fi
    if ! "${VENV_DIR}/bin/python" -m pip --version >/dev/null 2>&1; then
        "${VENV_DIR}/bin/python" -m ensurepip --upgrade >/dev/null 2>&1 || true
    fi
    if ! "${VENV_DIR}/bin/python" -m pip --version >/dev/null 2>&1; then
        fail_user_visible "安装失败：虚拟环境已创建但 pip 不可用。"
    fi
    "${VENV_DIR}/bin/python" -m pip install -U pip >/dev/null 2>&1 || true
    if ! "${VENV_DIR}/bin/python" -m pip install -r "${REQ_FILE}"; then
        fail_user_visible "安装失败：Python 依赖安装失败。"
    fi
    return 0
}

_install_with_target() {
    rm -rf "${PY_TARGET}" 2>/dev/null || true
    mkdir -p "${PY_TARGET}"
    : > "${TRIM_PKGVAR}/.use_python_target"
    rm -rf "${VENV_DIR}" 2>/dev/null || true
    if ! python3 -m pip install -r "${REQ_FILE}" -t "${PY_TARGET}"; then
        fail_user_visible "安装失败：pip install --target 失败。"
    fi
}

VENV_DIR="${TRIM_PKGVAR}/venv"
PY_TARGET="${TRIM_PKGVAR}/python_modules"

if [ -x "${VENV_DIR}/bin/python" ] && [ ! -f "${TRIM_PKGVAR}/.use_python_target" ]; then
    "${VENV_DIR}/bin/python" -m pip install -U pip >/dev/null 2>&1 || true
    if ! "${VENV_DIR}/bin/python" -m pip install -r "${REQ_FILE}"; then
        fail_user_visible "安装失败：更新 Python 依赖失败。"
    fi
elif [ -f "${TRIM_PKGVAR}/.use_python_target" ] && [ -d "${PY_TARGET}" ]; then
    if ! python3 -m pip install -r "${REQ_FILE}" -t "${PY_TARGET}"; then
        fail_user_visible "安装失败：更新 Python 依赖失败（target 模式）。"
    fi
elif ! _install_with_venv; then
    _install_with_target
fi

exit 0
